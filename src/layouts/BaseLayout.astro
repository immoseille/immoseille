---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/instrument-sans';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Imm'oseille | Formation au métier de marchand de biens",
  description = "Apprenez le métier de marchand de biens : montage d'opération, sourcing off-market, négociation, marge et fiscalité. Une formation de terrain pour vous lancer et vous professionnaliser.",
  image = '/logo-mark-512.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Imm'oseille" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />
    <meta name="twitter:card" content="summary_large_image" />

    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <a href="#contenu" class="skip-link">Aller au contenu</a>
    <Header />
    <main id="contenu">
      <slot />
    </main>
    <Footer />
    <style is:global>
      :root {
        /* Palette : papier chaud, encre, vert oseille, or */
        --paper: #f3efe4;
        --paper-2: #ebe4d4;
        --paper-3: #e2d9c4;
        --ink: #17150f;
        --ink-soft: #4c473b;
        --ink-faint: #8b8474;
        --green: #0f3a26;
        --green-bright: #1c5a3c;
        --gold: #b8923f;
        --line: rgba(23, 21, 15, 0.14);
        --line-soft: rgba(23, 21, 15, 0.08);

        --font-display: 'Fraunces Variable', Georgia, 'Times New Roman', serif;
        --font-body: 'Instrument Sans Variable', system-ui, -apple-system, sans-serif;

        --wrap: 1200px;
        --radius: 4px;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        -webkit-text-size-adjust: 100%;
      }

      body {
        font-family: var(--font-body);
        color: var(--ink);
        background-color: var(--paper);
        /* grain + trame plan discrète */
        background-image:
          linear-gradient(var(--line-soft) 1px, transparent 1px),
          linear-gradient(90deg, var(--line-soft) 1px, transparent 1px);
        background-size: 46px 46px, 46px 46px;
        background-position: -1px -1px, -1px -1px;
        line-height: 1.6;
        font-size: 17px;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        overflow-x: hidden;
      }

      main {
        min-height: 50vh;
      }

      h1, h2, h3, h4 {
        font-family: var(--font-display);
        font-weight: 560;
        line-height: 1.04;
        letter-spacing: -0.015em;
        color: var(--ink);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      .wrap {
        width: 100%;
        max-width: var(--wrap);
        margin-inline: auto;
        padding-inline: clamp(1.2rem, 4vw, 2.75rem);
      }

      .skip-link {
        position: absolute;
        left: -999px;
        top: 0;
        background: var(--ink);
        color: var(--paper);
        padding: 0.6rem 1rem;
        z-index: 999;
      }
      .skip-link:focus {
        left: 0;
      }

      /* Boutons */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-body);
        font-weight: 600;
        font-size: 0.98rem;
        letter-spacing: 0.01em;
        padding: 0.85rem 1.5rem;
        border-radius: var(--radius);
        border: 1.5px solid var(--ink);
        cursor: pointer;
        transition: transform 0.18s ease, background-color 0.18s ease, color 0.18s ease;
        line-height: 1;
      }
      .btn--primary {
        background: var(--ink);
        color: var(--paper);
      }
      .btn--primary:hover {
        background: var(--green);
        border-color: var(--green);
        transform: translateY(-2px);
      }
      .btn--ghost {
        background: transparent;
        color: var(--ink);
      }
      .btn--ghost:hover {
        background: var(--ink);
        color: var(--paper);
        transform: translateY(-2px);
      }

      .eyebrow {
        font-family: var(--font-body);
        font-weight: 600;
        font-size: 0.78rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--gold);
      }

      @media (prefers-reduced-motion: reduce) {
        * {
          animation: none !important;
          transition: none !important;
          scroll-behavior: auto !important;
        }
      }
    </style>
  </body>
</html>
