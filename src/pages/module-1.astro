---
import BaseLayout from '../layouts/BaseLayout.astro';

const CALENDLY = 'https://calendly.com/immoseille/appel-decouverte';
// TODO: remplace par ton vrai espace Skool
const SKOOL = 'https://www.skool.com/immoseille';

const chapitres = [
  { n: '1.1', t: 'Pourquoi le sourcing est le nerf du métier', d: "Une opération se gagne à l’achat, pas à la revente." },
  { n: '1.2', t: 'Construire un réseau d’apporteurs', d: "Agents, notaires, artisans, gestionnaires : qui contacter et comment." },
  { n: '1.3', t: 'Accéder aux biens off-market', d: "Trouver les biens qui ne passent jamais par une annonce publique." },
  { n: '1.4', t: 'Détecter un bien à potentiel', d: "Les signaux qui font une bonne opération, et les pièges à fuir." },
  { n: '1.5', t: 'Activer les bons canaux', d: "Où chercher vraiment, et où vous perdez votre temps." },
];
---

<BaseLayout
  title="Module 1 : Sourcing & off-market | Imm'oseille"
  description="Aperçu du module 1 de la formation marchand de biens : le sourcing et l'off-market, le nerf du métier. Un avant-goût concret du programme."
>
  <section class="mhero">
    <div class="wrap">
      <a href="/formation" class="back">&larr; La formation</a>
      <p class="eyebrow">Module 1 · Aperçu</p>
      <h1>Sourcing &amp; off-market</h1>
      <p class="mhero-sub">
        Le point de départ du métier : trouver les bonnes opérations avant tout
        le monde. Voici un avant-goût de ce que couvre le premier module.
      </p>
    </div>
  </section>

  <section class="section preview-wrap">
    <div class="wrap">
      <div class="video-frame" aria-label="Aperçu vidéo du module 1">
        <div class="play"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z" /></svg></div>
        <span class="video-label">Aperçu vidéo · Module 1</span>
      </div>
    </div>
  </section>

  <section class="section chapitres">
    <div class="wrap chap-grid">
      <div class="chap-head">
        <p class="eyebrow">Au programme</p>
        <h2>Ce que couvre le module 1</h2>
        <p class="lede">Cinq chapitres, du concept au terrain, pour savoir où et comment trouver vos opérations.</p>
      </div>
      <ol class="chap-list">
        {chapitres.map((c) => (
          <li class="chap-item">
            <span class="chap-num">{c.n}</span>
            <div>
              <h3>{c.t}</h3>
              <p>{c.d}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section avantgout">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Un avant-goût</p>
        <h2>Trois notions à retenir dès maintenant</h2>
      </div>
      <div class="taste-grid">
        <article class="taste">
          <h3>La marge se fait à l’achat</h3>
          <p>Si vous achetez au bon prix, la rentabilité est déjà en grande partie sécurisée. La revente ne fait que confirmer un travail déjà gagné en amont, au sourcing.</p>
        </article>
        <article class="taste">
          <h3>Le off-market, c’est quoi</h3>
          <p>Ce sont les biens qui se vendent sans annonce publique. Moins de concurrence, donc plus de marge de négociation. C’est là que se montent les meilleures opérations.</p>
        </article>
        <article class="taste">
          <h3>L’erreur du débutant</h3>
          <p>Attendre les biens sur les portails classiques. À ce stade, tout le monde les voit, la concurrence a fait monter le prix, et la marge a déjà disparu.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section unlock">
    <div class="wrap unlock-inner">
      <h2>Ça vous parle ? La suite est dans la formation</h2>
      <p>Les cinq autres modules, les cas réels et l’accompagnement vous attendent. Commencez par un appel, on regarde si c’est fait pour vous.</p>
      <div class="unlock-cta">
        <a href={CALENDLY} class="btn btn--primary">Réserver un appel &rarr;</a>
        <a href={SKOOL} class="btn btn--ghost" rel="noopener">Accéder à la formation</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section { padding-top: clamp(2.5rem, 6vw, 4.5rem); padding-bottom: clamp(2.5rem, 6vw, 4.5rem); }
  .section-head { max-width: 44ch; margin-bottom: clamp(1.5rem, 3vw, 2.5rem); }
  .section-head h2 { font-size: clamp(1.8rem, 3.6vw, 2.6rem); margin: 0.5rem 0 0.7rem; }
  .lede { color: var(--ink-soft); font-size: 1.04rem; }

  .mhero { padding-top: clamp(2rem, 5vw, 3.5rem); padding-bottom: 0.5rem; }
  .back { display: inline-block; margin-bottom: 1.4rem; color: var(--ink-soft); font-size: 0.9rem; font-weight: 500; }
  .back:hover { color: var(--gold); }
  .mhero h1 { font-size: clamp(2.4rem, 5.6vw, 4rem); margin: 0.8rem 0 1.1rem; }
  .mhero-sub { color: var(--ink-soft); font-size: clamp(1.02rem, 1.5vw, 1.18rem); max-width: 52ch; }

  /* VIDEO PLACEHOLDER */
  .preview-wrap { padding-top: clamp(1.5rem, 3vw, 2rem); }
  .video-frame { position: relative; aspect-ratio: 16/9; border: 1.5px solid var(--ink); border-radius: 12px; overflow: hidden; display: grid; place-items: center;
    background: linear-gradient(135deg, var(--green) 0%, #0a2a1b 100%); box-shadow: 16px 16px 0 -2px var(--paper-3), 16px 16px 0 0 var(--ink); }
  .play { width: 84px; height: 84px; border-radius: 50%; background: var(--gold); display: grid; place-items: center; box-shadow: 0 10px 30px -8px rgba(0,0,0,0.5); }
  .play svg { width: 38px; height: 38px; fill: var(--ink); margin-left: 4px; }
  .video-label { position: absolute; bottom: 1rem; left: 1.2rem; color: color-mix(in srgb, var(--paper) 85%, transparent); font-size: 0.82rem; letter-spacing: 0.08em; text-transform: uppercase; }

  /* CHAPITRES */
  .chap-grid { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
  .chap-head { position: sticky; top: 96px; }
  .chap-list { list-style: none; display: grid; gap: 0.8rem; counter-reset: none; }
  .chap-item { display: flex; gap: 1.1rem; align-items: flex-start; background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 1.2rem 1.3rem; }
  .chap-num { font-family: var(--font-display); font-weight: 600; color: var(--gold); font-size: 1.05rem; flex: none; padding-top: 0.1rem; }
  .chap-item h3 { font-size: 1.15rem; margin-bottom: 0.2rem; }
  .chap-item p { color: var(--ink-soft); font-size: 0.95rem; }

  /* AVANT-GOUT */
  .avantgout { background: var(--paper-2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .taste-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }
  .taste { background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 1.6rem; border-top: 3px solid var(--gold); }
  .taste h3 { font-size: 1.25rem; margin-bottom: 0.6rem; }
  .taste p { color: var(--ink-soft); font-size: 0.97rem; }

  /* UNLOCK */
  .unlock { text-align: center; }
  .unlock-inner h2 { font-size: clamp(1.9rem, 4vw, 2.9rem); max-width: 22ch; margin-inline: auto; }
  .unlock-inner p { color: var(--ink-soft); max-width: 52ch; margin: 1rem auto 2rem; font-size: 1.06rem; }
  .unlock-cta { display: flex; gap: 0.85rem; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 900px) {
    .chap-grid { grid-template-columns: 1fr; }
    .chap-head { position: static; }
    .taste-grid { grid-template-columns: 1fr; }
  }
</style>
