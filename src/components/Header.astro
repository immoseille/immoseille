---
const links = [
  { href: '/formation', label: 'La formation' },
  { href: '/operations', label: 'Résultats' },
  { href: '/guides', label: 'Guides' },
  { href: '/a-propos', label: 'À propos' },
];
---

<header class="site-header">
  <div class="wrap header-inner">
    <a href="/" class="brand" aria-label="Imm'oseille — accueil">
      <span class="brand-mark">Imm<span class="apos">'</span>oseille</span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />
    <label for="nav-toggle" class="burger" aria-label="Ouvrir le menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="nav" aria-label="Navigation principale">
      {links.map((l) => (
        <a href={l.href} class="nav-link">{l.label}</a>
      ))}
      <a href="/rendez-vous" class="btn btn--primary nav-cta">Réserver un appel</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .brand-mark {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .brand-mark .apos {
    color: var(--brick);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.4vw, 2.1rem);
  }

  .nav-link {
    font-weight: 500;
    font-size: 0.98rem;
    color: var(--ink-soft);
    position: relative;
    padding: 0.25rem 0;
    transition: color 0.15s ease;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 1.5px;
    background: var(--brick);
    transition: width 0.22s ease;
  }
  .nav-link:hover {
    color: var(--ink);
  }
  .nav-link:hover::after {
    width: 100%;
  }

  .nav-cta {
    padding: 0.62rem 1.1rem;
    font-size: 0.9rem;
  }

  /* Burger (mobile) */
  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 0.4rem;
  }
  .burger span {
    width: 26px;
    height: 2px;
    background: var(--ink);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  @media (max-width: 860px) {
    .burger {
      display: flex;
    }
    .nav {
      position: fixed;
      inset: 72px 0 auto 0;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
      background: var(--paper);
      border-bottom: 1px solid var(--line);
      padding: 1.25rem clamp(1.2rem, 4vw, 2.75rem) 1.75rem;
      transform: translateY(-120%);
      transition: transform 0.3s ease;
      box-shadow: 0 18px 40px -22px rgba(23, 21, 15, 0.4);
    }
    .nav-link {
      font-size: 1.15rem;
      padding: 0.5rem 0;
    }
    .nav-cta {
      margin-top: 0.75rem;
      width: 100%;
      justify-content: center;
      padding: 0.85rem 1.1rem;
      font-size: 0.98rem;
    }
    .nav-toggle:checked ~ .nav {
      transform: translateY(0);
    }
    .nav-toggle:checked ~ .burger span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .nav-toggle:checked ~ .burger span:nth-child(2) {
      opacity: 0;
    }
    .nav-toggle:checked ~ .burger span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
